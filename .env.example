# Waylo Backend — environment variables
# Copy to .env and fill in real values. NEVER commit .env.

# AWS Bedrock (Claude) — powers /plan, /vision and /vision-fallback
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
# Bedrock model id or inference profile id.
# Amazon Nova Pro (text + vision, no Marketplace subscription needed):
#   us.amazon.nova-pro-v1:0
# Anthropic Claude 4-series requires the regional inference-profile prefix (us.)
# AND a completed Anthropic AWS Marketplace subscription, e.g.
#   us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0

# Supabase — guide persistence
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key

# Server
PORT=3000
