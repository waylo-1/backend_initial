# Waylo Backend — environment variables
# Copy to .env and fill in real values. NEVER commit .env.

# Which AI provider services/llm.js uses. "bedrock" or "gemini". Default: bedrock.
AI_PROVIDER=bedrock

# ── AWS Bedrock (Amazon Nova) — used when AI_PROVIDER=bedrock ──────────────
# Powers /plan, /vision, /vision-fallback, /qa, /ask-screen, /recover, /nova-vision.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# Text-only calls (plan generation, /qa). Nova Micro is cheap and plenty
# capable for structured JSON / short answers.
# New name. Old name (still read, new one wins if both set): BEDROCK_PLAN_MODEL_ID
BEDROCK_TEXT_MODEL_ID=us.amazon.nova-micro-v1:0

# Vision calls with a screenshot (/vision locate+troubleshoot, /vision-fallback,
# /recover, /ask-screen).
# New name. Old name (still read, new one wins if both set): BEDROCK_MODEL_ID
BEDROCK_VISION_MODEL_ID=us.amazon.nova-lite-v1:0

# Object-detection/bbox grounding for /nova-vision. Nova 2 Lite is specifically
# tuned for this; kept separate from BEDROCK_VISION_MODEL_ID.
# New name. Old name (still read, new one wins if both set): BEDROCK_VISION_MODEL_ID
# (yes, the same old var name backs both roles above — see the comment in
# services/providers/bedrock.js if you have both an old .env and want the two
# roles on different models)
BEDROCK_OBJECT_DETECT_MODEL_ID=us.amazon.nova-2-lite-v1:0

# Deprecated names — still read for backward compatibility, prefer the ones above:
#   BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0
#   BEDROCK_PLAN_MODEL_ID=us.amazon.nova-micro-v1:0

# ── Google Gemini — used when AI_PROVIDER=gemini ────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash

# Supabase — guide persistence
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key

# Spotify (optional) — enables autonomous "play X on Spotify".
# Create a free app at https://developer.spotify.com/dashboard, then copy its
# Client ID + Secret here. Without these, "play X" still opens Spotify's in-app
# search (it just won't auto-start playback). No redirect URI / user login
# needed — this uses the client-credentials flow for catalogue search only.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Server
PORT=3000
